# Panoptes environment variables.
# Copy to ".env.local" (git-ignored) and fill in. All keys are read SERVER-SIDE only
# (inside Next.js route handlers under src/app/api/*). Never expose them to the client.
#
# Most layers work WITHOUT any keys (USGS, GDELT, ReliefWeb*, adsb.lol, World Bank,
# OpenStreetMap/Protomaps demo tiles). Keys only unlock the noted realtime feeds.

# --- Aviation ---
# OpenSky Network (OAuth2 client credentials). adsb.lol /v2/mil needs no key.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# --- Maritime ---
# AISStream.io websocket key (Ops > vessels layer)
AIS_STREAM_KEY=

# --- Space / satellites ---
# Space-Track.org account (TLE source; ToS: do not expose bulk TLE to anon users)
SPACETRACK_USER=
SPACETRACK_PASS=
N2YO_API_KEY=

# --- Disasters / humanitarian ---
# ReliefWeb requires an appname (any identifier string)
RELIEFWEB_APP_NAME=panoptes-dev
# HDX HAPI (Analytics conflict events) — register at https://hapi.humdata.org/
HAPI_APP_IDENTIFIER=
# Optional override (default https://hapi.humdata.org/api/v2)
# HAPI_BASE_URL=

# NASA FIRMS active-fire MAP_KEY (optional; layer degrades gracefully without it)
FIRMS_MAP_KEY=

# --- Information environment ---
VOIDLY_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Economic ---
EIA_API_KEY=
FRED_API_KEY=
UN_COMTRADE_API_KEY=

# --- Conflict ---
UCDP_API_KEY=

# --- Basemap (optional) ---
# Leave blank to use the free Protomaps demo / self-hosted PMTiles basemap.
# A self-hosted basemap PMTiles URL (https or /tiles/...) overrides the demo source.
NEXT_PUBLIC_BASEMAP_PMTILES_URL=

# Optional cross-request cache (Upstash Redis REST). Falls back to in-memory if unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
