# Panoptes environment variables.
# Copy keys into src/.env (git-ignored) — this repo's convention for secrets.
# Optional: .env.local at repo root also works (Next.js standard).
# Server-side only (API routes + npm run ais:relay). Never expose secrets to the client.
#
# Most layers work WITHOUT any keys (USGS, GDELT, adsb.lol, World Bank,
# OpenStreetMap/Protomaps demo tiles). Keys only unlock the noted realtime feeds.

# Data dump url for static-data/
# DATA_DUMP_URL=

# --- Aviation ---
# OpenSky Network (OAuth2 client credentials). adsb.lol /v2/mil needs no key.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# --- Maritime ---
# AISStream.io API key — used by the local relay (npm run ais:relay) and /api/vessels fallback.
AIS_STREAM_KEY=
# Optional relay port (default 8787)
# AIS_RELAY_PORT=8787
# Browser WebSocket URL for the local AIS relay (client-side only, not secret)
NEXT_PUBLIC_AIS_WS_URL=ws://127.0.0.1:8787/ws

# --- Space / satellites ---
# Space-Track.org account (TLE source; ToS: do not expose bulk TLE to anon users)
SPACETRACK_USER=
SPACETRACK_PASS=
# N2YO_API_KEY=

# --- Disasters / humanitarian ---
# ReliefWeb requires an appname parameter to be set in the API requests (see: https://apidoc.reliefweb.int/parameters#appname)
RELIEFWEB_APP_NAME=
# HDX HAPI (Analytics conflict events)
HAPI_APP_IDENTIFIER=
# Optional override (default https://hapi.humdata.org/api/v2)
# HAPI_BASE_URL=

# NASA FIRMS active-fire MAP_KEY (optional; layer degrades gracefully without it)
NASA_FIRMS_MAP_KEY=

# --- Information environment ---
# VOIDLY_API_KEY=
CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# --- Economic ---
EIA_API_KEY=
FRED_API_KEY=
UN_COMTRADE_API_KEY=

# --- Conflict ---
UCDP_API_KEY=

# --- Basemap (optional) ---
# Leave blank to use the free Protomaps demo / self-hosted PMTiles basemap.
# A self-hosted basemap PMTiles URL (https or /tiles/...) overrides the demo source.
# NEXT_PUBLIC_BASEMAP_PMTILES_URL=

# Optional cross-request cache (Upstash Redis REST). Falls back to in-memory if unset.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
